<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
        <title>Document</title>
    </head>
    <body>
        
        <div class="bg-zinc-900 flex justify-start px-10 py-4">
            <a href="/login" class="text-blue-500 hover:underline text-sm">
                Login
            </a>
       </div>

        <div class="w-full h-screen bg-zinc-900 text-white px-10 py-8">
           <h1 class="text-2xl font-semibold mb-6">Create User</h1>

            <form method="post" action="/create" class="flex gap-2 items-center">

                <input 
                type="text" 
                name="username" 
                placeholder="username"
                class="bg-transparent border border-zinc-700 px-3 py-2 rounded-md outline-none focus:border-blue-500"
                >

                <input 
                type="email" 
                name="email" 
                placeholder="email"
                class="bg-transparent border border-zinc-700 px-3 py-2 rounded-md outline-none focus:border-blue-500"
                >

                <input 
                type="password" 
                name="password" 
                placeholder="password"
                class="bg-transparent border border-zinc-700 px-3 py-2 rounded-md outline-none focus:border-blue-500"
                >

                <input 
                type="number" 
                name="age" 
                placeholder="age"
                class="bg-transparent border border-zinc-700 px-3 py-2 rounded-md outline-none focus:border-blue-500 w-20"
                >

                <button 
                type="submit"
                class="bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded-md text-sm"
                >
                Create User
                </button>

            </form>

        </div>
    </body>
</html>