<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
        <title>Document</title>
    </head>
    <body>
        
        <div class="w-full h-screen bg-zinc-900 text-white px-10 py-8">
           <h1 class="text-2xl font-semibold mb-6">Login Your Account</h1>

            <form method="post" action="/login" class="flex gap-2 items-center">

                <input 
                type="email" 
                name="email" 
                placeholder="email"
                class="bg-transparent border border-zinc-700 px-3 py-2 rounded-md outline-none focus:border-blue-500"
                >

                <input 
                type="password" 
                name="password" 
                placeholder="password"
                class="bg-transparent border border-zinc-700 px-3 py-2 rounded-md outline-none focus:border-blue-500"
                >
                
                <button 
                type="submit"
                class="bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded-md text-sm"
                >
                Login
                </button>

            </form>

        </div>
    </body>
</html>