<!DOCTYPE html>
<html lang="en">
    <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile</title>
    <script src="https://cdn.tailwindcss.com"></script>
    </head>
    <body class="bg-zinc-950 min-h-screen p-3 text-white">

        <div class="flex justify-end">
            <a href="/logout"
            class="px-3 py-1 text-xs bg-red-500 hover:bg-red-600 rounded transition">
            Logout
            </a>
        </div>

        <div class="max-w-md ml-4">

            <h1 class="text-3xl font-semibold leading-tight">
            Hello, <%= user.name %> 👋🏻
            </h1>
            <p class="text-sm text-zinc-400 mb-6">
            you can create a new post.
            </p>

  
            <form action="/posts" method="post" class="space-y-3">
            <textarea
                name="content"
                rows="3"
                placeholder="What's on your mind ?"
                class="w-full px-4 py-3 bg-transparent border border-zinc-800 rounded-md text-sm outline-none focus:border-blue-500 resize-none"
            ></textarea>

            <button
                type="submit"
                class="px-5 py-2 text-sm bg-blue-600 hover:bg-blue-700 rounded transition">
                Create New Post
            </button>
            </form>


            <div class="mt-12 w-[560px] space-y-4">

                <h2 class="text-xl font-semibold text-zinc-200 mb-5">
                    Your Posts.
                </h2>

                 <% user.posts.forEach(function(post){ %>

                    <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-4 shadow-md">

                        <h3 class="text-blue-500 text-lg font-semibold mb-2">
                            @<%= user.username %>
                        </h3>

                        <p class="text-white text-base leading-relaxed mb-4">
                            <%= post.content %>
                        </p>

                        <small class="mt-2 inline-block text-zinc-400">
                            <%= post.likes.length %> likes
                        </small>

                        <div class="flex gap-4 mt-3">
                            <a href="/like/<%= post._id %>" class="text-blue-500 hover:underline text-base">
                                Like
                            </a>

                            <a href="/edit/<%= post._id %>" class="text-zinc-500 hover:text-white text-base">
                                Edit
                            </a>
                        </div>

                    </div>

                <% }) %>

            </div>
        </div>

    </body>
</html>