<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <script src="https://cdn.tailwindcss.com"></script>
        <link rel="stylesheet" href="stylesheets\style.css">
        <title>Project</title>
    </head>
    <body class="w-full h-full bg-black ">
        
        <div class="main w-full h-full bg-black text-white p-10">
            <nav class="w-full mb-6">
                <a href="/" class="text-blue-400 hover:underline text-sm font-semibold">
                    ← Back to Home
                </a>
            </nav>

            <h1 class="text-2xl font-semibold mb-6">All Users</h1>

            <form action="/read" method="POST" class="flex flex-wrap gap-8 items-center">
                <% if (users.length > 0) { %>
                    <% users.forEach(function(user){ %>

                        <div class="bg-zinc-900 p-5 rounded-xl shadow-lg">
                            <div class="w-full h-40 bg-zinc-800 rounded-lg mb-4 overflow-hidden">
                                <img class="w-full h-full object-cover" src="<%= user.image %>" />
                            </div>
                            <h2 class="text-lg font-semibold"><%= user.name %></h2>
                            <p class="text-gray-400 text-sm mb-4"><%=  user.email %></p>
                            <div class="flex gap-4">
                                <a href="/edit/<%= user._id %>" class="text-blue-400 hover:underline">Edit User</a>
                                <a href="/delete/<%= user._id %>" class="text-red-500 hover:underline">Delete User</a>
                            </div>
                        </div>
                    
                    
                        <% }) %>
                <% } else { %>
                 <h3 class="text-gray-400">No users yet</h3>

                 <% } %>
                

             
            </form>
        </div>
                
                
        <script src="/javascript/script.js"></script>
    </body>
</html>